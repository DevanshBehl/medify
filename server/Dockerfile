# ──────────────────────────────────────────────
# Stage 1: Production build
# ──────────────────────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package*.json ./
RUN npm ci --omit=dev

# Copy source
COPY . .

EXPOSE 5000

CMD ["node", "server.js"]
